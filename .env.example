# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Reddit API Credentials (Optional)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=python:answerai:v1.0.0 (by /u/yourusername)

# Dev.to Credentials (Optional)
DEVTO_API_KEY=your_devto_api_key

# StackOverflow Credentials (Optional)
STACKOVERFLOW_KEY=your_stackoverflow_key

# Twitter/X Credentials (Optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Scraper Enable Toggles
ENABLE_MEDIUM_SCRAPING=false
ENABLE_TWITTER_SCRAPING=false

# Cache Configuration (TTL in seconds)
RAW_CACHE_TTL=21600
ANSWER_CACHE_TTL=3600

# Backend/Frontend Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=sqlite:///./answerai.db

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000
